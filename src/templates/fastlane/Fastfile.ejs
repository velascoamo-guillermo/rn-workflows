# Auto-generated by rn-workflows. Do not edit by hand.
# Regenerate with: npx rn-workflows generate

default_platform(:android)

before_all do
  if ENV["ASC_KEY_ID"] && ENV["ASC_ISSUER_ID"] && ENV["ASC_KEY_CONTENT"]
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: ENV["ASC_KEY_IS_BASE64"] == "true",
      in_house: false
    )
  end
end

<% for (const profile of androidProfiles) { -%>
platform :android do
  desc "<%= profile.description %>"
  lane :<%= profile.name %> do
    gradle(
      task: "<%= profile.gradleTask %>",
      build_type: "Release",
      project_dir: "android/"
    )
<% if (profile.targets.includes('firebase')) { -%>
    firebase_app_distribution(
      app: ENV["FIREBASE_APP_ID_ANDROID"],
      service_credentials_json_data: ENV["FIREBASE_SERVICE_ACCOUNT_JSON"],
      groups: "internal-testers",
      <%= profile.isAab ? 'android_artifact_type: "AAB",' : '' %>
      <%= profile.isAab ? 'android_artifact_path' : 'apk_path' %>: "<%= profile.androidArtifactPath %>"
    )
<% } -%>
<% if (profile.targets.includes('store')) { -%>
    upload_to_play_store(
      json_key_data: ENV["PLAY_STORE_JSON_KEY"],
      package_name: "<%= packageName %>",
      track: "production",
      aab: "<%= profile.androidArtifactPath %>"
    )
<% } -%>
  end
end

<% } -%>
<% for (const profile of iosProfiles) { -%>
platform :ios do
  desc "<%= profile.description %>"
  lane :<%= profile.name %> do
    setup_ci if ENV["CI"]
    match(type: "<%= profile.matchType %>", readonly: ENV.fetch("MATCH_READONLY", "true") == "true") if ENV["MATCH_PASSWORD"]
    build_app(
      workspace: "ios/<%= profile.xcWorkspace %>.xcworkspace",
      scheme: "<%= profile.xcScheme %>",
      export_method: "<%= profile.exportMethod %>",
      output_directory: "ios/build",
      xcargs: "CODE_SIGN_STYLE=Manual PROVISIONING_PROFILE_SPECIFIER='match <%= profile.matchType === 'adhoc' ? 'AdHoc' : profile.matchType === 'app-store' ? 'AppStore' : 'Development' %> <%= bundleId %>' CODE_SIGN_IDENTITY='iPhone Distribution'",
      export_options: {
        method: "<%= profile.exportMethod %>",
        provisioningProfiles: {
          "<%= bundleId %>" => "match <%= profile.matchType === 'adhoc' ? 'AdHoc' : profile.matchType === 'app-store' ? 'AppStore' : 'Development' %> <%= bundleId %>"
        }
      }
    )
<% if (profile.targets.includes('firebase')) { -%>
    firebase_app_distribution(
      app: ENV["FIREBASE_APP_ID_IOS"],
      service_credentials_json_data: ENV["FIREBASE_SERVICE_ACCOUNT_JSON"],
      groups: "internal-testers",
      googleservice_info_plist_path: "GoogleService-Info.plist"
    )
<% } -%>
<% if (profile.targets.includes('testflight')) { -%>
    upload_to_testflight(
      api_key_path: ENV["APP_STORE_CONNECT_API_KEY_PATH"],
      skip_waiting_for_build_processing: true
    )
<% } -%>
<% if (profile.targets.includes('store')) { -%>
    upload_to_app_store(
      api_key_path: ENV["APP_STORE_CONNECT_API_KEY_PATH"],
      force: true,
      skip_metadata: true,
      skip_screenshots: true
    )
<% } -%>
  end
end

<% } -%>
<% if (usesFirebase) { -%>
lane :add_testers do |options|
  emails    = options[:emails] || UI.input("Tester emails (comma-separated):")
  group     = options[:group] || "internal-testers"
  creds_file = "/tmp/rn-workflows-sa.json"
  File.write(creds_file, ENV["FIREBASE_SERVICE_ACCOUNT_JSON"])
  firebase_app_distribution_add_testers(
    project_number: ENV["FIREBASE_PROJECT_NUMBER"],
    service_credentials_file: creds_file,
    emails: emails,
    group_alias: group
  )
  File.delete(creds_file)
end

lane :remove_testers do |options|
  emails    = options[:emails] || UI.input("Tester emails to remove (comma-separated):")
  creds_file = "/tmp/rn-workflows-sa.json"
  File.write(creds_file, ENV["FIREBASE_SERVICE_ACCOUNT_JSON"])
  firebase_app_distribution_remove_testers(
    project_number: ENV["FIREBASE_PROJECT_NUMBER"],
    service_credentials_file: creds_file,
    emails: emails
  )
  File.delete(creds_file)
end

<% } -%>
<% if (hasIos) { -%>
platform :ios do
  lane :add_device do |options|
    name = options[:name] || UI.input("Device name:")
    udid = options[:udid] || UI.input("Device UDID:")
    register_devices(devices: { name => udid })
    require 'spaceship'
    Spaceship::ConnectAPI::Device.enable(udid)
    match(type: "adhoc", force_for_new_devices: true)
  end

  lane :list_devices do
    require 'spaceship'
    devices = Spaceship::ConnectAPI::Device.all
    UI.message "\n📱 Registered devices (#{devices.count}):"
    devices.each do |d|
      UI.message "  #{d.name.to_s.ljust(30)} #{d.udid}  [#{d.platform}] #{d.status}"
    end
  end

  lane :regenerate_certs do
    match(type: "adhoc", force: true)
  end

  lane :remove_device do |options|
    udid = options[:udid] || UI.input("Device UDID to disable:")
    require 'spaceship'
    device = Spaceship::ConnectAPI::Device.all.find { |d| d.udid == udid }
    if device
      Spaceship::ConnectAPI::Device.disable(device.udid)
      UI.success("Disabled #{device.name} (#{udid})")
    else
      UI.error("Device with UDID #{udid} not found")
    end
  end
end

<% } -%>
