# Auto-generated by rn-workflows. Do not edit by hand.
# Regenerate with: npx rn-workflows generate

name: <%= workflowName %>

on:
  workflow_dispatch:
  push:
    branches: [<%= branch %>]

jobs:
<% for (const job of jobs) { -%>
  <%= job.id %>:
    name: <%= job.name %>
    runs-on: <%= job.runsOn %>
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: 20
<% if (packageManager !== 'bun') { -%>
          cache: <%= packageManager %>
<% } -%>

<% if (packageManager === 'bun') { -%>
      - name: Setup Bun
        uses: oven-sh/setup-bun@v2

<% } -%>
      - name: Setup Ruby
        uses: ruby/setup-ruby@v1
        with:
          ruby-version: 3.2
          bundler-cache: true

<% if (job.platform === 'ios') { -%>
      - name: Select Xcode
        uses: maxim-lobanov/setup-xcode@v1
        with:
          xcode-version: latest-stable
<% } -%>
<% if (job.platform === 'android') { -%>
      - name: Setup JDK
        uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: 17
<% } -%>

      - name: Install JS dependencies
        run: <%= packageManager === 'bun' ? 'bun install --frozen-lockfile' : packageManager === 'npm' ? 'npm ci' : 'yarn install --frozen-lockfile' %>

<% if (job.platform === 'ios') { -%>
      - name: Expo Prebuild (iOS)
        run: npx expo prebuild --platform ios --no-install

      - name: Install Pods
        run: cd ios && pod install --repo-update

<% } -%>
<% if (job.platform === 'android') { -%>
      - name: Expo Prebuild (Android)
        run: npx expo prebuild --platform android --no-install

<% } -%>
      - name: Run Fastlane lane <%= job.lane %> (<%= job.platform %>)
        run: bundle exec fastlane <%= job.platform %> <%= job.lane %>
        env:
<% for (const secret of job.secrets) { -%>
          <%= secret %>: ${{ secrets.<%= secret %> }}
<% } -%>
<% if (job.platform === 'ios' && job.secrets.some(s => s === 'MATCH_PASSWORD')) { -%>
          MATCH_GIT_BASIC_AUTHORIZATION: ${{ secrets.MATCH_GIT_BASIC_AUTHORIZATION }}
<% } -%>
<% if (job.platform === 'android') { -%>
          GRADLE_OPTS: "-Dorg.gradle.jvmargs=-Xmx4g -XX:MaxMetaspaceSize=1g"
<% } -%>

<% } -%>
