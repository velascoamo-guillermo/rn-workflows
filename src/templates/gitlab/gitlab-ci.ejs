# Auto-generated by rn-workflows. Do not edit by hand.
# Regenerate with: npx rn-workflows generate

stages:
  - build

.node_cache: &node_cache
  cache:
    key: ${CI_COMMIT_REF_SLUG}
    paths:
      - node_modules/

<% for (const job of jobs) { -%>
<%= job.id %>:
  stage: build
  image: <%= job.image %>
  <<: *node_cache
<% if (job.branch) { -%>
  only:
    - <%= job.branch %>
<% } -%>
  before_script:
    - yarn install --frozen-lockfile
    - bundle install
  script:
    - bundle exec fastlane <%= job.platform %> <%= job.lane %>
  variables:
<% for (const secret of job.secrets) { -%>
    <%= secret %>: $<%= secret %>
<% } -%>
  artifacts:
    paths:
<% if (job.platform === 'android') { -%>
      - android/app/build/outputs/
<% } else { -%>
      - ios/build/
<% } -%>
    expire_in: 1 week

<% } -%>
