// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`generateGitlab output matches snapshot 1`] = `
"# Auto-generated by rn-workflows. Do not edit by hand.
# Regenerate with: npx rn-workflows generate

stages:
  - build

.node_cache: &node_cache
  cache:
    key: \${CI_COMMIT_REF_SLUG}
    paths:
      - node_modules/

build:preview:android:
  stage: build
  image: reactnativecommunity/react-native-android:latest
  <<: *node_cache
  only:
    - develop
  before_script:
    - yarn install --frozen-lockfile
    - bundle install
  script:
    - bundle exec fastlane android preview
  variables:
    FIREBASE_APP_ID_ANDROID: $FIREBASE_APP_ID_ANDROID
    FIREBASE_SERVICE_ACCOUNT_JSON: $FIREBASE_SERVICE_ACCOUNT_JSON
  artifacts:
    paths:
      - android/app/build/outputs/
    expire_in: 1 week

"
`;
